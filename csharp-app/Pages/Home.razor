@page "/"
@inject CourseService Course
<PageTitle>C# Start | はじめてのC#</PageTitle>
<header class="topbar"><a class="brand" href="./">C# Start</a><a href="../index.html">PythonLearnへ</a></header>
<main class="shell"><section class="hero"><p class="eyebrow">C# FOR BEGINNERS</p><h1>作りたいものから、<br />C#を始めよう。</h1><p>ゲームやアプリ作りにつながるC#を、短いコードと小さな成功体験で学びます。</p><div class="progress">進捗：@Passed.Count / @Course.Lessons.Count レッスン合格</div></section><section class="course"><aside class="lesson-list"><h2>学習の道のり</h2>@foreach(var item in Course.Lessons){<button class="@(item==Current?"selected":"")" @onclick="()=>Select(item)"><span>@item.Number.ToString("00")</span><strong>@item.Title</strong><small>@(Passed.Contains(item.Number)?"合格済み":"これから")</small></button>}</aside><article class="lesson"><p class="eyebrow">LESSON @Current.Number.ToString("00")</p><h2>@Current.Title</h2><p>@Current.Summary</p><div class="goal"><strong>このレッスンのゴール</strong><br />@Current.Goal</div><label for="code">コードを書いてみよう</label><textarea id="code" @bind="Code" spellcheck="false"></textarea><div class="actions"><button class="primary" @onclick="Check">答えを確認</button><button @onclick="()=>ShowHintText=true">ヒントを見る</button><button @onclick="()=>ShowSolutionText=true">模範解答</button></div>@if(ShowHintText){<p class="hint">@Current.Hint</p>}@if(ShowSolutionText){<pre><code>@Current.SolutionCode</code></pre>}@if(Result is not null){<p class="result @(Result.Passed?"passed":"failed")">@Result.Message</p>}</article></section></main>
@code { private Lesson Current=null!; private string Code=""; private CheckResult? Result; private bool ShowHintText; private bool ShowSolutionText; private HashSet<int> Passed=[]; protected override void OnInitialized()=>Select(Course.Lessons[0]); private void Select(Lesson lesson){Current=lesson;Code=lesson.StarterCode;Result=null;ShowHintText=false;ShowSolutionText=false;} private void Check(){Result=Course.Check(Current,Code);if(Result.Passed)Passed.Add(Current.Number);} }
